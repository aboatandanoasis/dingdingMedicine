/* 老人端主页样式 - 极简大字版 */

/* 页面容器 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #e8f4fc 0%, #f5f7fa 100%);
  padding-bottom: 320rpx;
}

/* 顶部日期提示 */
.header {
  padding: 40rpx 30rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.header-left {
  display: flex;
  flex-direction: column;
}

.date {
  display: block;
  font-size: 32rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.greeting {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: #1296db;
}

.header-right {
  padding: 16rpx 24rpx;
  background: rgba(18, 150, 219, 0.1);
  border-radius: 12rpx;
}

.history-link {
  font-size: 28rpx;
  color: #1296db;
}

/* 药品列表 */
.medicine-list {
  padding: 0 30rpx;
}

/* 滑动删除容器 */
.slide-container {
  position: relative;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.slide-content {
  position: relative;
  z-index: 2;
  background: #fff;
  transition: transform 0.2s ease-out;
}

/* 删除按钮（默认隐藏在右侧） */
.delete-btn-wrapper {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

.delete-btn {
  width: 120rpx;
  height: 100%;
  background: #f44336;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-text {
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
}

/* 药品卡片 */
.medicine-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.medicine-card.taken {
  background: linear-gradient(135deg, #e8f5e9 0%, #f1f8e9 100%);
  border-left: 6rpx solid #4CAF50;
}

/* 药品图片 */
.medicine-image-box {
  width: 80rpx;
  height: 80rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.medicine-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.medicine-image-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #e3f2fd 0%, #f3e5f5 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #bdbdbd;
}

.placeholder-text {
  font-size: 20rpx;
  color: #999;
}

/* 药品信息 */
.medicine-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.medicine-name {
  font-size: 48rpx;
  font-weight: 600;
  color: #333;
}

.medicine-desc {
  font-size: 30rpx;
  color: #666;
}

.medicine-dosage {
  font-size: 28rpx;
  color: #999;
}

/* 状态标签 - 红绿灯样式 */
.medicine-status {
  margin-left: 20rpx;
  flex-shrink: 0;
  padding: 8rpx;
  border-radius: 12rpx;
}

.status-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  min-width: 120rpx;
}

.status-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-symbol {
  font-size: 40rpx;
  font-weight: bold;
}

.status-label {
  font-size: 32rpx;
  font-weight: 500;
  white-space: nowrap;
}

/* 已吃：绿色对勾 */
.status-done {
  background: #4CAF50;
}

.status-done .icon-symbol {
  color: #fff;
}

.label-done {
  color: #4CAF50;
}

/* 过时未吃：红色叉号 */
.status-overdue {
  background: #f44336;
}

.status-overdue .icon-symbol {
  color: #fff;
}

.label-overdue {
  color: #f44336;
}

/* 未到时间：黄色圆圈 */
.status-pending {
  background: #FFC107;
  border: 4rpx solid #FF9800;
}

.status-pending .icon-symbol {
  color: #fff;
}

.label-pending {
  color: #FF9800;
}

/* 无药品提示 */
.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 30rpx;
  line-height: 1.8;
}

/* 一键确认按钮 */
.confirm-section {
  position: fixed;
  bottom: 160rpx;
  left: 30rpx;
  right: 30rpx;
}

.confirm-btn {
  width: 100%;
  height: 220rpx;
  line-height: 220rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #388E3C 100%);
  color: #fff;
  font-size: 56rpx;
  font-weight: 600;
  border-radius: 24rpx;
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(76, 175, 80, 0.4);
  padding: 0;
  text-align: center;
}

.confirm-btn::after {
  border: none;
}

.confirm-btn.completed {
  background: linear-gradient(135deg, #bdbdbd 0%, #9e9e9e 100%);
  box-shadow: none;
}

.btn-hover {
  opacity: 0.9;
  transform: scale(0.98);
}

/* 添加药物按钮 */
.add-section {
  position: fixed;
  bottom: 40rpx;
  left: 30rpx;
  right: 30rpx;
}

.add-btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  background: #fff;
  color: #1296db;
  font-size: 36rpx;
  font-weight: 500;
  border-radius: 16rpx;
  border: 3rpx solid #1296db;
  padding: 0;
  text-align: center;
}

.add-btn::after {
  border: none;
}

/* 弹窗遮罩 */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

/* 弹窗内容 */
.dialog {
  width: 90%;
  max-height: 80vh;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  box-sizing: border-box;
}

.dialog-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 40rpx;
}

.input-group {
  margin-bottom: 30rpx;
}

.input-label {
  display: block;
  font-size: 30rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.input-field {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.picker-field {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  box-sizing: border-box;
  color: #333;
}

.dialog-buttons {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-top: 40rpx;
  width: 100%;
}

.dialog-cancel,
.dialog-confirm {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  border-radius: 12rpx;
  border: none;
  padding: 0;
  text-align: center;
  min-width: 0;
}

.dialog-cancel::after,
.dialog-confirm::after {
  border: none;
}

.dialog-cancel {
  background: #f5f5f5;
  color: #666;
}

.dialog-confirm {
  background: #1296db;
  color: #fff;
}

/* 编辑弹窗图片 */
.edit-image-box {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-image {
  width: 100%;
  height: 100%;
}

.edit-image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #e3f2fd 0%, #f3e5f5 100%);
  border: 2rpx dashed #bdbdbd;
  border-radius: 16rpx;
}

.edit-image-placeholder .placeholder-text {
  font-size: 24rpx;
  color: #999;
}
